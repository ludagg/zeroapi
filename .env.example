# Base de données (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/zeroapi"

# Claude API
ANTHROPIC_API_KEY=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Chiffrement des secrets (EnvVariable.value) — AES-256-GCM
# Génère 32 bytes en base64 : `openssl rand -base64 32`
SECRETS_ENCRYPTION_KEY=

# Trigger.dev v3 (sdk/v3)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_ACCOUNT_ID=

# Resend
RESEND_API_KEY=

# Redis
REDIS_URL=

# LLM providers (au moins un requis)
MISTRAL_API_KEY=
GEMINI_API_KEY=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ZeroAPI Cloud (déploiement via Coolify — plans PRO/BUSINESS)
COOLIFY_API_URL=http://167.86.95.165:8000
COOLIFY_API_TOKEN=
COOLIFY_PROJECT_UUID=
COOLIFY_SERVER_UUID=
