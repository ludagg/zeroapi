# =============================================================================
# ZeroAPI — variables d'environnement de PRODUCTION
# =============================================================================
# Copie ce fichier en .env.production sur ta plateforme d'hébergement
# (ou directement dans son dashboard de variables : Railway / Render / Fly /
# Vercel). NE LE COMMITE JAMAIS avec des valeurs renseignées.
#
# Les variables marquées [REQUIS] doivent être définies pour que l'app démarre.
# Les autres activent des fonctionnalités optionnelles.
# =============================================================================


# -----------------------------------------------------------------------------
# Base de données — PostgreSQL [REQUIS]
# -----------------------------------------------------------------------------
# URL complète au format `postgresql://user:password@host:port/db?sslmode=require`.
# En prod, exige `sslmode=require` (ou `verify-full` selon ton CA).
DATABASE_URL=


# -----------------------------------------------------------------------------
# App [REQUIS]
# -----------------------------------------------------------------------------
# Domaine public de la plateforme, sans slash final, ex : https://app.zeroapi.app
# Utilisé pour les redirects OAuth, les liens dans les emails, et baseURL Better Auth.
NEXT_PUBLIC_APP_URL=
NODE_ENV=production


# -----------------------------------------------------------------------------
# Better Auth [REQUIS]
# -----------------------------------------------------------------------------
# Secret de signature des sessions / cookies. Minimum 32 caractères.
# Génère-le : `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# URL canonique de l'instance (doit matcher NEXT_PUBLIC_APP_URL en HTTPS).
BETTER_AUTH_URL=


# -----------------------------------------------------------------------------
# Chiffrement des secrets utilisateurs [REQUIS]
# -----------------------------------------------------------------------------
# Clé AES-256-GCM pour chiffrer les `EnvVariable.value` au repos.
# Format : 32 bytes encodés en base64.
# Génère-la : `openssl rand -base64 32`
# CRITICAL : si tu perds cette clé, toutes les variables stockées sont irrécupérables.
SECRETS_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# Fournisseurs LLM — au moins un requis
# -----------------------------------------------------------------------------
# Le routeur (lib/llm-router.ts) bascule automatiquement selon le plan utilisateur
# et fallback sur les autres providers en cas d'erreur. Active au minimum Claude
# pour garantir la qualité des specs.

# Anthropic Claude — recommandé pour PRO/BUSINESS (spec_generation, complex_spec).
ANTHROPIC_API_KEY=

# Mistral — utilisé pour les plans FREE/STARTER (conversation, validation).
MISTRAL_API_KEY=

# Google Gemini — fallback alternatif.
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# Trigger.dev v3 [REQUIS si tu veux les jobs asynchrones]
# -----------------------------------------------------------------------------
# Sans ces variables, le worker tourne en best-effort dans le process Next
# (suffisant pour valider une démo, pas pour la prod).
# Récupère-les sur https://cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=


# -----------------------------------------------------------------------------
# Cloudflare R2 — stockage des bundles ZIP [REQUIS en prod]
# -----------------------------------------------------------------------------
# Sans R2, le worker tombe sur un fallback local dans `.bundles/` qui ne survit
# pas aux redéploiements et n'est pas partagé entre instances.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# (Optionnel) URL publique du bucket si tu as configuré un custom domain R2.
# Sans cette URL, ZeroAPI mint des URLs signées valables 7 jours pour chaque download.
R2_PUBLIC_URL=


# -----------------------------------------------------------------------------
# Resend — emails transactionnels [REQUIS]
# -----------------------------------------------------------------------------
# Les emails « job prêt » et « erreur de génération » passent par Resend.
# Vérifie ton domaine d'envoi pour éviter le spam : https://resend.com/domains
RESEND_API_KEY=

# Adresse expéditrice (le domaine doit être vérifié dans Resend).
RESEND_FROM="ZeroAPI <noreply@zeroapi.app>"


# -----------------------------------------------------------------------------
# Redis — cache & rate-limit multi-instance [REQUIS si >1 instance]
# -----------------------------------------------------------------------------
# Sans Redis, le rate-limit reste en mémoire locale (incohérent en multi-pod).
# Format `redis://default:<password>@<host>:<port>` ou `rediss://` pour TLS.
REDIS_URL=


# -----------------------------------------------------------------------------
# OAuth — Google (optionnel)
# -----------------------------------------------------------------------------
# Console : https://console.cloud.google.com/apis/credentials
# Redirect URI à enregistrer : ${NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# OAuth — GitHub (optionnel)
# -----------------------------------------------------------------------------
# Settings : https://github.com/settings/developers
# Authorization callback URL : ${NEXT_PUBLIC_APP_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Observabilité (optionnel, recommandé)
# -----------------------------------------------------------------------------
# Sentry pour le tracking d'erreurs côté serveur et client.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=


# =============================================================================
# Checklist avant le go-live
# =============================================================================
# [ ] DATABASE_URL pointe sur une Postgres managée (Neon, Supabase, Railway Pg)
#     avec backups automatiques activés.
# [ ] `pnpm prisma migrate deploy` exécuté contre cette base.
# [ ] BETTER_AUTH_SECRET et SECRETS_ENCRYPTION_KEY générés via openssl
#     (et stockés dans le secret manager, jamais dans le repo).
# [ ] Domaine d'envoi Resend vérifié + record DKIM/SPF/DMARC propre.
# [ ] R2_PUBLIC_URL configuré (sinon les ZIP passent par URL signée 7j).
# [ ] TRIGGER_SECRET_KEY configuré → workers OOP (sinon fallback local).
# [ ] Au moins ANTHROPIC_API_KEY défini pour la qualité des specs Pro.
# [ ] Healthcheck `/` retourne 200 derrière le load balancer.
# =============================================================================
